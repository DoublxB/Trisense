# Google AI Studio: https://aistudio.google.com/apikey — Quickstart: https://ai.google.dev/gemini-api/docs/quickstart
GEMINI_API_KEY=your-gemini-api-key-here
# Optional: ex. gemini-2.5-flash sau gemini-3-flash-preview (vezi quickstart)
# GEMINI_MODEL=gemini-2.5-flash

MQTT_BROKER=broker.hivemq.com
MQTT_PORT=1883
MQTT_CLIENT_ID_PC=TriSense_PC_Brain_3

# Dialog prin microfon ESP (TCP): IP PC pentru testare/mqtt_voice_listen_test.py; port server
# PC_VOICE_IP=192.168.0.10
# VOICE_TCP_PORT=8765
# Model Gemini pentru transcriere audio (optional)
# GEMINI_TRANSCRIBE_MODEL=gemini-2.0-flash

# 0 = fara pyttsx3 pe PC; doar difuzor ESP prin MQTT speak (Gemini TTS pe robot)
# TRISENSE_TTS_PC=0
