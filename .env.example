# --- Plată --- AI Studio GEMINI_API_KEY e separată de GCP. Cu trial-ul Cloud folosești
# Vertex + Neural2 TTS: cheie_google.json + (opțional) TRISENSE_TTS_PCM_SOURCE=google_cloud .
# NU pune GEMINI_API_KEY dacă nu vrei billing AI Studio; lasă Gemini doar via Vertex (= facturabil pe proiectul GCP cu credite trial).
GEMINI_USE_VERTEX=1
# Regiune: Gemini 3.x preview necesită de obicei `global`; alte modele pot folosi europe-west4.
GCP_LOCATION=global
# Opțional (altfel citește project_id din cheie_google.json):
# GCP_PROJECT=my-gcp-project
# Gemini 3.1 Flash preview pe Vertex — dacă 404 pentru proiectul tău, schimbă:
# GEMINI_MODEL=gemini-3-flash-preview
# GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_MODEL=gemini-3.1-flash-preview
# Opțional: cale explicită la JSON (în loc sau în plus față de ./cheie_google.json)
# GOOGLE_APPLICATION_CREDENTIALS=C:\\Users\\YOU\\Desktop\\Licenta mea\\cheie_google.json

# --- Opție: Google AI Studio (fără Vertex) ---
# Preferi Gemini prin AI Studio (GEMINI_API_KEY) în loc de Vertex chiar dacă există cheie_google.json?
# GEMINI_USE_VERTEX=0
# GEMINI_API_KEY=your-gemini-api-key-here

# pcm gemini | google_cloud — google_cloud = Text-to-Speech API (Neural2), aceeași contă GCP; fără cheie Gemini pe ESP dacă PCM ajunge mereu pe TCP
# TRISENSE_TTS_PCM_SOURCE=google_cloud
# GCP_TTS_VOICE=en-US-Neural2-F
# GCP_TTS_LANGUAGE=en-US

# PCM sintetizat pe PC către ESP (dacă folosești difuzorul prin TCP)
# TRISENSE_TTS_OVER_TCP=1

MQTT_BROKER=192.168.100.134
MQTT_PORT=1883
MQTT_CLIENT_ID_PC=TriSense_PC_Brain_3

# --- Rețea: PC vs robot (nu amesteca) ---
# Laptop (ipconfig) — ESP se conecteaza la serverul TCP de voce de pe PC folosind acest IP.
PC_VOICE_IP=192.168.100.134
VOICE_TCP_PORT=8765

# Placa ESP — IP afisat la WiFi pe serial. Pentru test_laptop_mic + PCM pe difuzor: seteaza + TRISENSE_TTS_OVER_TCP=1
# ROBOT_ESP_IP=192.168.100.xx
TRISENSE_TTS_OVER_TCP=1
# ESP_AUDIO_TCP_PORT=8766
# GEMINI_TRANSCRIBE_MODEL=gemini-3.1-flash-preview

# OPTIONAL: HuskyLens
# VISION_ID_TO_ACTION={"21":"dance","22":"breathe_in"}
